# OpenAI — optional. App works with intelligent fallback responses when unset.
OPENAI_API_KEY=

# ---------- Supabase ----------
# Required for authentication, profiles, and incident persistence.
# Leave blank to run the app in fully open "demo mode" (no auth, in-memory store).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — used by privileged jobs (seeding demo users, admin scripts).
# NEVER prefix this with NEXT_PUBLIC_ and never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used for auth email redirect links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
